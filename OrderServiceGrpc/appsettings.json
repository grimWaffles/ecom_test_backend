    "SqlServerHomeConnection": "Server=localhost;Database=ECommercePlatform;User Id=sa;Password=SA@12345678#;TrustServerCertificate=True;",
    "SqlServerHomeDockerConnection": "Server=host.docker.internal,1433;Database=ECommercePlatform;User=sa;Password=SA@12345678#;TrustServerCertificate=True;"
  },

  "KafkaGlobalSettings": {
    "BootstrapServerLocal": "localhost:9093",
    "BootstrapServerDocker": "kafka:9092",
    "Mode": "docker"
  },

  "KafkaConsumerSettings": {
    "BootstrapServer": "localhost:9093",
    "OrderGroupId": "OrderConsumer",
    "TransactionGroupId": "TransactionConsumer",
    "EnableAutoCommit": false,
    "EnableAutoOffsetStore": false,
    "AutoOffsetReset": "Earliest",
    "AutoCommitIntervalInMs": 3000,
    "MaxConsumerRetries": 3,
    "ConsumerMessageBatchSize": 100,
    "MaxDelayBetweenCommitsInMs": 100,

    "DlqAcks": "All",
    "DlqMessageTimeoutMs": 5000,
    "DlqIdempotence": true,

    "CatchAllDlqTopic": "catch-all-dlq"
  },

  "KafkaProducerSettings": {
    "MessageTimeoutMs": 5000,
    "RetryAfterDelayMs": 200,
    "MaxNoOfRetries": 3,
    "EnableIdempotence": true,
    "TotalPartitions": 6,
    "Acks": "All"
  },

  "OrderEventConsumerSettings": {
    "GroupId": "OrderConsumer",
    "TopicsToConsume": [
      "order-create",
      "order-update",
      "order-delete",
      "transaction-create-failed",
      "transaction-update-failed",
      "transaction-delete-failed"
    ],
    "TopicsToProduce": [
      "order-create-success",
      "order-update-success",
      "order-delete-success"
    ],
    "DlqTopicsToProduce": [
      "order-create-dlq",
      "order-update-dlq",
      "order-delete-dlq"
    ]
  },

  "TransactionEventConsumerSettings": {
    "GroupId": "TransactionConsumer",
    "TopicsToConsume": [
      "order-create-success",
      "order-update-success",
      "order-delete-success"
    ],
    "TopicsToProduce": [
      "transaction-create-success",
      "transaction-update-success",
      "transaction-delete-success",
      "transaction-create-failed",
      "transaction-update-failed",
      "transaction-delete-failed"
    ]
  },

  "AllowedHosts": "*",

  "Kestrel": {
    "EndpointDefaults": {
      "Protocols": "Http2"
    }
  }

}