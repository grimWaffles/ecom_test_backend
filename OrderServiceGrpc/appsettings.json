{
  "Logging": {
    "LogLevel": {
      "Default": "Critical",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "DatabaseConfig": {
    "Database": "work",
    "Mode": "docker"
  },

  "ConnectionStrings": {
