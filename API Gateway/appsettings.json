{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "MicroServiceUrls": {
    "Mode": "local",
    "LocalUrls": {
      "userService": "http://localhost:5258",
      "productService": "http://localhost:5156",
      "orderService": "http://localhost:5104"
    },
    "DockerUrls": {
      "userService": "http://UserServiceContainer:5001",
      "productService": "http://ProductServiceContainer:5002",
      "orderService": "http://OrderServiceContainer:5004"
    }
  },

  "Kafka": {
    "BootstrapServerLocal": "localhost:9093",
    "BootstrapServerDocker": "kafka:9092",
    "Mode": "local"
  },

  "KafkaProducerSettings": {
    "MessageTimeoutMs": 5000,
    "RetryAfterDelayMs": 200,
    "MaxNoOfRetries": 3,
    "EnableIdempotence": true,
    "TotalPartitions": 6,
    "Acks": "All"
  },

  "Jwt": {
    "validIssuer": "localhost",
    "validAudience": "localhost",
    "SigningKey": "123456789123456789123456789123456789"
  },

  "Redis": {
    "url": "localhost:6379"
  },

  "AllowedHosts": "*"
}
